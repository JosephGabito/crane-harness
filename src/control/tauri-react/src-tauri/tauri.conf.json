{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Loop",
  "version": "0.1.0",
  "identifier": "ai.agentloop.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run sidecar:build && npm run build",
    "frontendDist": "../dist",
    "additionalWatchFolders": [
      "../../../agent_loop",
      "../../../control/sidecar",
      "../../../../main.py"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Agent Loop",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'"
      },
      "devCsp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "img-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/agent-loop-sidecar/": "agent-loop-runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
